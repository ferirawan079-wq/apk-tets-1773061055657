<?xml version='1.0' encoding='utf-8'?>
<widget id="Com.testmob.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Tets</name>
    <description>Built with APK Builder Pro</description>
    <author>APK Builder Pro</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-navigation href="*" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="android-targetSdkVersion" value="33" />
    <preference name="android-minSdkVersion" value="22" />
    <preference name="Orientation" value="portrait" />
    <preference name="loadUrlTimeoutValue" value="60000" />
    <platform name="android">
        <preference name="AndroidWindowSplashScreenBackground" value="#7c6fff" />
    </platform>
</widget>